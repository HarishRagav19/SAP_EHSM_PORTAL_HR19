<mvc:View
    controllerName="ehsm.portal.controller.EmployeeProfile"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fcard="sap.f.cards"
    xmlns:l="sap.ui.layout"
    xmlns:tnt="sap.tnt"
>
    <Page id="employeeProfilePage" showHeader="false">
        <tnt:ToolPage id="profileToolPage">
        <tnt:header>
            <tnt:ToolHeader>
                <Button icon="sap-icon://menu2" type="Transparent" press="onSideNavButtonPress"/>
                <Title text="SAP EHSM Portal" class="sapUiSmallMarginBegin"/>
                <ToolbarSpacer/>
                <Button icon="sap-icon://log" type="Transparent" press="onLogout"/>
            </tnt:ToolHeader>
        </tnt:header>
        
        <tnt:sideContent>
            <tnt:SideNavigation selectedKey="profile" itemSelect="onItemSelect">
                <tnt:item>
                    <tnt:NavigationList>
                        <tnt:NavigationListItem text="Dashboard" icon="sap-icon://home" key="dashboard"/>
                        <tnt:NavigationListItem text="Incident Management" icon="sap-icon://warning" key="incidents"/>
                        <tnt:NavigationListItem text="Risk Assessment" icon="sap-icon://shield" key="risks"/>
                        <tnt:NavigationListItem text="Safety Actions" icon="sap-icon://task" key="safetyActions"/>
                        <tnt:NavigationListItem text="Hazard Analysis" icon="sap-icon://alert" key="hazardAnalysis"/>
                    </tnt:NavigationList>
                </tnt:item>
                <tnt:fixedItem>
                    <tnt:NavigationList>
                        <tnt:NavigationListItem text="Employee Profile" icon="sap-icon://employee" key="profile"/>
                    </tnt:NavigationList>
                </tnt:fixedItem>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <tnt:mainContents>
            <ScrollContainer vertical="true" horizontal="false" height="100%" class="ehsmMainContent">
                <VBox class="sapUiMediumMargin">
                    <Title text="Employee Profile" level="H2" class="ehsmDashboardTitle sapUiSmallMarginBottom"/>

                    <f:Card class="sapUiSmallMarginBottom" width="700px">
                        <f:header>
                            <fcard:Header title="Personal Information" subtitle="Professional Profile Details" iconSrc="sap-icon://employee"/>
                        </f:header>
                        <f:content>
                            <l:VerticalLayout class="sapUiContentPadding" width="100%">
                                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                    <Avatar src="sap-icon://customer" displaySize="XL" class="sapUiSmallMarginEnd" backgroundColor="Accent6"/>
                                    <VBox>
                                        <Title text="{prof>/EmployeeName}" level="H2"/>
                                        <Text text="{prof>/Designation}"/>
                                    </VBox>
                                </HBox>
                                
                                <l:Grid defaultSpan="L6 M6 S12" class="sapUiSmallMarginTop">
                                    <VBox class="sapUiSmallMarginBottom">
                                        <Label text="Employee ID" design="Bold"/>
                                        <Text text="{prof>/EmpId}"/>
                                    </VBox>
                                    <VBox class="sapUiSmallMarginBottom">
                                        <Label text="Department" design="Bold"/>
                                        <Text text="{prof>/Department}"/>
                                    </VBox>
                                    <VBox class="sapUiSmallMarginBottom">
                                        <Label text="Plant Location" design="Bold"/>
                                        <Text text="{prof>/Plant}"/>
                                    </VBox>
                                    <VBox class="sapUiSmallMarginBottom">
                                        <Label text="Gender" design="Bold"/>
                                        <Text text="{prof>/Gender}"/>
                                    </VBox>
                                </l:Grid>
                            </l:VerticalLayout>
                        </f:content>
                    </f:Card>
                </VBox>
            </ScrollContainer>
        </tnt:mainContents>
    </tnt:ToolPage>
    </Page>
</mvc:View>
