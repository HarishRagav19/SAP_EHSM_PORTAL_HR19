<mvc:View
    controllerName="ehsm.portal.controller.IncidentManagement"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:tnt="sap.tnt"
>
    <Page id="incidentManagementPage" showHeader="false">
        <tnt:ToolPage id="incidentToolPage">
        <tnt:header>
            <tnt:ToolHeader>
                <Button icon="sap-icon://menu2" type="Transparent" press="onSideNavButtonPress"/>
                <Image src="https://www.kaartech.com/wp-content/uploads/2017/05/Kaar-Tech-Logo.png" width="100px" class="sapUiSmallMarginBegin"/>
                <Title text="Incident Management" class="sapUiSmallMarginBegin"/>
                <ToolbarSpacer/>
                <Button icon="sap-icon://log" type="Transparent" press="onLogout"/>
            </tnt:ToolHeader>
        </tnt:header>
        
        <tnt:sideContent>
            <tnt:SideNavigation selectedKey="incidents" itemSelect="onItemSelect">
                <tnt:item>
                    <tnt:NavigationList>
                        <tnt:NavigationListItem text="Dashboard" icon="sap-icon://view-lux" key="dashboard"/>
                        <tnt:NavigationListItem text="Incident Management" icon="sap-icon://warning" key="incidents"/>
                        <tnt:NavigationListItem text="Risk Assessment" icon="sap-icon://shield" key="risks"/>
                        <tnt:NavigationListItem text="Employee Profile" icon="sap-icon://employee" key="profile"/>
                    </tnt:NavigationList>
                </tnt:item>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <tnt:mainContents>
            <ScrollContainer vertical="true" horizontal="false" height="100%">
                <VBox class="sapUiMediumMargin">
                    <Table id="incidentTable" items="{/INCIDENTSet}" sticky="ColumnHeaders">
                        <headerToolbar>
                            <OverflowToolbar>
                                <Title text="Recorded Incidents" level="H2"/>
                                <ToolbarSpacer/>
                                <SearchField width="300px" search="onSearch"/>
                                <Button icon="sap-icon://add" text="Report Incident" type="Emphasized" press="onReportIncident"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <columns>
                            <Column width="120px">
                                <Text text="Incident ID"/>
                            </Column>
                            <Column minScreenWidth="Tablet" demandPopin="true">
                                <Text text="Description"/>
                            </Column>
                            <Column width="120px">
                                <Text text="Date"/>
                            </Column>
                            <Column width="100px">
                                <Text text="Type"/>
                            </Column>
                            <Column width="120px">
                                <Text text="Plant"/>
                            </Column>
                            <Column width="120px">
                                <Text text="Status"/>
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem type="Navigation" press="onIncidentPress">
                                <cells>
                                    <ObjectIdentifier title="{Qmnum}"/>
                                    <Text text="{Qmtxt}"/>
                                    <Text text="{Qmdat}"/>
                                    <ObjectAttribute text="{Qmart}"/>
                                    <Text text="{Swerk}"/>
                                    <ObjectStatus text="Active" state="Warning"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>
            </ScrollContainer>
        </tnt:mainContents>
    </tnt:ToolPage>
    </Page>
</mvc:View>
