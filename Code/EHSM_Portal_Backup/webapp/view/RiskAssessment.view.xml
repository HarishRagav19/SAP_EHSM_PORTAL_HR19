<mvc:View
    controllerName="ehsm.portal.controller.RiskAssessment"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fcard="sap.f.cards"
    xmlns:tnt="sap.tnt"
    xmlns:l="sap.ui.layout"
>
    <Page id="riskAssessmentPage" showHeader="false">
        <tnt:ToolPage id="riskToolPage">
        <tnt:header>
            <tnt:ToolHeader>
                <Button icon="sap-icon://menu2" type="Transparent" press="onSideNavButtonPress"/>
                <Image src="https://www.kaartech.com/wp-content/uploads/2017/05/Kaar-Tech-Logo.png" width="100px" class="sapUiSmallMarginBegin"/>
                <Title text="Risk Assessment" class="sapUiSmallMarginBegin"/>
                <ToolbarSpacer/>
                <Button icon="sap-icon://log" type="Transparent" press="onLogout"/>
            </tnt:ToolHeader>
        </tnt:header>
        
        <tnt:sideContent>
            <tnt:SideNavigation selectedKey="risks" itemSelect="onItemSelect">
                <tnt:item>
                    <tnt:NavigationList>
                        <tnt:NavigationListItem text="Dashboard" icon="sap-icon://view-lux" key="dashboard"/>
                        <tnt:NavigationListItem text="Incident Management" icon="sap-icon://warning" key="incidents"/>
                        <tnt:NavigationListItem text="Risk Assessment" icon="sap-icon://shield" key="risks"/>
                        <tnt:NavigationListItem text="Employee Profile" icon="sap-icon://employee" key="profile"/>
                    </tnt:NavigationList>
                </tnt:item>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <tnt:mainContents>
            <ScrollContainer vertical="true" horizontal="false" height="100%">
                <VBox class="sapUiMediumMargin">
                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                        <Title text="Risk Registry" level="H2"/>
                    </HBox>

                    <l:Grid containerQuery="true" defaultSpan="XL6 L6 M12 S12">
                        <List items="{/RISKASSESSMENTSet}" headerText="Active Risks">
                            <CustomListItem>
                                <HBox class="sapUiSmallMargin" justifyContent="SpaceBetween">
                                    <VBox>
                                        <Title text="{HazardType}" level="H4"/>
                                        <Text text="Severity: {Severity}"/>
                                    </VBox>
                                    <ObjectStatus 
                                        text="{RiskLevel}" 
                                        state="{path: 'RiskLevel', formatter: '.formatter.riskState'}"
                                        icon="sap-icon://status-critical"/>
                                </HBox>
                            </CustomListItem>
                        </List>
                        
                        <f:Card>
                            <f:header>
                                <fcard:Header title="Risk Matrix" subtitle="Impact vs Probability"/>
                            </f:header>
                            <f:content>
                                <VBox class="sapUiContentPadding" alignItems="Center">
                                    <Image src="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e0/Risk_Matrix.png/300px-Risk_Matrix.png" width="250px"/>
                                </VBox>
                            </f:content>
                        </f:Card>
                    </l:Grid>
                </VBox>
            </ScrollContainer>
        </tnt:mainContents>
    </tnt:ToolPage>
    </Page>
</mvc:View>
