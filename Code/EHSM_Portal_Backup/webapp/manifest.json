{
  "_version": "1.12.0",
  "sap.app": {
    "id": "ehsm.portal",
    "type": "application",
    "title": "EHSM Portal",
    "description": "EHSM Safety Engineer Portal",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZHR19_EHSM_PROJECT_SRV/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0",
          "localUri": "localService/metadata.xml"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.tnt": {},
        "sap.ui.layout": {},
        "sap.suite.ui.microchart": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "ehsm.portal.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "defaultOperationMode": "Server",
          "defaultBindingMode": "TwoWay",
          "defaultCountMode": "Request"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "rootView": {
      "viewName": "ehsm.portal.view.App",
      "type": "XML",
      "id": "app",
      "async": true
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "ehsm.portal.view",
        "controlAggregation": "pages",
        "controlId": "app"
      },
      "routes": [
        {
          "name": "login",
          "pattern": "",
          "target": [
            "login"
          ]
        },
        {
          "name": "dashboard",
          "pattern": "dashboard",
          "target": [
            "dashboard"
          ]
        },
        {
          "name": "incidents",
          "pattern": "incidents",
          "target": [
            "incidents"
          ]
        },
        {
          "name": "risks",
          "pattern": "risks",
          "target": [
            "risks"
          ]
        },
        {
          "name": "profile",
          "pattern": "profile",
          "target": [
            "profile"
          ]
        },
        {
          "name": "compliance",
          "pattern": "compliance",
          "target": [
            "compliance"
          ]
        },
        {
          "name": "safetyActions",
          "pattern": "safetyActions",
          "target": [
            "safetyActions"
          ]
        },
        {
          "name": "incidentHistory",
          "pattern": "incidentHistory",
          "target": [
            "incidentHistory"
          ]
        },
        {
          "name": "hazardAnalysis",
          "pattern": "hazardAnalysis",
          "target": [
            "hazardAnalysis"
          ]
        },
        {
          "name": "incidentDetail",
          "pattern": "incidents/{qmnum}",
          "target": [
            "incidentDetail"
          ]
        }
      ],
      "targets": {
        "login": {
          "viewId": "login",
          "viewName": "Login"
        },
        "dashboard": {
          "viewId": "dashboard",
          "viewName": "Dashboard"
        },
        "incidents": {
          "viewId": "incidents",
          "viewName": "IncidentManagement"
        },
        "risks": {
          "viewId": "risks",
          "viewName": "RiskAssessment"
        },
        "profile": {
          "viewId": "profile",
          "viewName": "EmployeeProfile"
        },
        "compliance": {
          "viewId": "compliance",
          "viewName": "Compliance"
        },
        "safetyActions": {
          "viewId": "safetyActions",
          "viewName": "SafetyActions"
        },
        "incidentHistory": {
          "viewId": "incidentHistory",
          "viewName": "IncidentHistory"
        },
        "hazardAnalysis": {
          "viewId": "hazardAnalysis",
          "viewName": "HazardAnalysis"
        },
        "incidentDetail": {
          "viewId": "incidentDetail",
          "viewName": "IncidentDetail"
        }
      }
    }
  }
}